rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['businessName', 'businessType', 'location', 'staff', 'challenge', 'leadSource', 'responseMethod', 'missedCalls', 'phone', 'email', 'desiredOutcome', 'preferredTime', 'createdAt'])
        && data.keys().size() == 13
        && data.businessName is string && data.businessName.size() <= 200
        && data.businessType is string && data.businessType.size() <= 100
        && data.location is string && data.location.size() <= 200
        && data.staff is string && data.staff.size() <= 100
        && data.challenge is string && data.challenge.size() <= 200
        && data.leadSource is string && data.leadSource.size() <= 200
        && data.responseMethod is string && data.responseMethod.size() <= 200
        && data.missedCalls is string && data.missedCalls.size() <= 100
        && data.phone is string && data.phone.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.desiredOutcome is string && data.desiredOutcome.size() <= 200
        && data.preferredTime is string && data.preferredTime.size() <= 100
        && data.createdAt == request.time;
    }

    // Since this is for a lead generation form, anyone can CREATE a lead.
    // They cannot READ, UPDATE, or DELETE leads unless they are an admin.
    // Wait, the rule says "never allow blanket reads", "validate type".
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      // Only admins should read. But we don't have admins right now, so false.
      allow read, update, delete: if false;
    }
  }
}
